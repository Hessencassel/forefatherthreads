{{ 'quote-cards.js' | asset_url | script_tag }}

{%- style -%}
  .fft-quote-section {
    background: #050505;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  @media screen and (max-width: 749px) {
    .fft-quote-section {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }
  }

  .fft-quote-section__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .fft-quote-section__header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .fft-quote-section__eyebrow {
    display: inline-block;
    font-family: "Roboto Mono", monospace;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #b91c1c;
    margin-bottom: 1rem;
  }

  .fft-quote-section__heading {
    font-family: Anton, serif;
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #ffffff;
    margin: 0 0 1rem;
    line-height: 1.1;
  }

  .fft-quote-section__subtext {
    font-family: "Roboto Mono", monospace;
    font-size: 0.85rem;
    color: #d1d1d1;
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .fft-quote-section__divider {
    width: 80px;
    height: 4px;
    background: #b91c1c;
    margin: 1.5rem auto 0;
  }

  /* ── Card grid ── */
  .fft-quote-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .fft-quote-card {
    background: #121212;
    border: 1px solid #222222;
    border-top: 3px solid #b91c1c;
    display: flex;
    flex-direction: column;
    position: relative;
    transition: border-color 0.25s, box-shadow 0.25s;
  }

  .fft-quote-card:hover {
    border-color: #b91c1c;
    box-shadow: 0 0 28px rgba(185, 28, 28, 0.18);
  }

  .fft-quote-card__body {
    padding: 2rem 2rem 1.25rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .fft-quote-card__mark {
    font-family: Anton, serif;
    font-size: 5rem;
    line-height: 0.7;
    color: #b91c1c;
    opacity: 0.22;
    user-select: none;
    margin-bottom: 0.5rem;
  }

  .fft-quote-card__text {
    font-family: Anton, serif;
    font-size: clamp(1.1rem, 2.5vw, 1.45rem);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #ffffff;
    line-height: 1.35;
    margin: 0 0 1.5rem;
    flex: 1;
  }

  .fft-quote-card__attribution {
    border-top: 1px solid #2a2a2a;
    padding-top: 1rem;
    margin-top: auto;
  }

  .fft-quote-card__author {
    font-family: Anton, serif;
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #c0a062;
    margin: 0 0 0.25rem;
  }

  .fft-quote-card__source {
    font-family: "Roboto Mono", monospace;
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    color: #888888;
    line-height: 1.5;
    margin: 0;
  }

  .fft-quote-card__source-note {
    display: block;
    margin-top: 0.3rem;
    font-style: italic;
    color: #666666;
  }

  /* ── Share button ── */
  .fft-quote-card__footer {
    padding: 0 2rem 1.75rem;
  }

  .fft-quote-card__share {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-family: "Roboto Mono", monospace;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #d1d1d1;
    background: transparent;
    border: 1px solid #333333;
    padding: 0.6rem 1.1rem;
    cursor: pointer;
    width: 100%;
    justify-content: center;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
  }

  .fft-quote-card__share:hover:not(:disabled) {
    border-color: #c0a062;
    color: #c0a062;
    background: rgba(192, 160, 98, 0.06);
  }

  .fft-quote-card__share:disabled {
    opacity: 0.55;
    cursor: wait;
  }

  .fft-quote-card__share-icon {
    width: 14px;
    height: 14px;
    fill: currentColor;
    flex-shrink: 0;
  }

  /* ── Footer CTA ── */
  .fft-quote-section__footer {
    text-align: center;
    margin-top: 3.5rem;
    padding-top: 2.5rem;
    border-top: 1px solid #1e1e1e;
  }

  .fft-quote-section__footer-text {
    font-family: "Roboto Mono", monospace;
    font-size: 0.82rem;
    letter-spacing: 0.06em;
    color: #888888;
    margin: 0 0 1.25rem;
    text-transform: uppercase;
  }

  .fft-quote-section__more-link {
    display: inline-block;
    font-family: Anton, serif;
    font-size: 0.95rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #ffffff;
    text-decoration: none;
    border-bottom: 2px solid #b91c1c;
    padding-bottom: 3px;
    transition: color 0.2s, border-color 0.2s;
  }

  .fft-quote-section__more-link:hover {
    color: #c0a062;
    border-color: #c0a062;
  }
{%- endstyle -%}

{%- liquid
  assign logo_url = ''
  if settings.logo != blank
    assign logo_url = settings.logo | image_url: width: 300
  endif
-%}

<section
  class="fft-quote-section"
  id="fft-quote-section-{{ section.id }}"
  data-fft-logo-url="{{ logo_url }}"
>
  <div class="fft-quote-section__inner">

    <header class="fft-quote-section__header">
      <span class="fft-quote-section__eyebrow">Primary Sources</span>
      <h2 class="fft-quote-section__heading">{{ section.settings.heading | escape }}</h2>
      {%- if section.settings.subtext != blank -%}
        <p class="fft-quote-section__subtext">{{ section.settings.subtext | escape }}</p>
      {%- endif -%}
      <div class="fft-quote-section__divider"></div>
    </header>

    <ul class="fft-quote-grid" role="list">

      <li class="fft-quote-card">
        <div class="fft-quote-card__body">
          <div class="fft-quote-card__mark" aria-hidden="true">&ldquo;</div>
          <p class="fft-quote-card__text">
            We hold these truths to be self-evident, that all men are created equal.
          </p>
          <div class="fft-quote-card__attribution">
            <p class="fft-quote-card__author">Thomas Jefferson</p>
            <p class="fft-quote-card__source">Declaration of Independence, July 4, 1776</p>
          </div>
        </div>
        <div class="fft-quote-card__footer">
          <button class="fft-quote-card__share" data-fft-share="0" type="button">
            <svg class="fft-quote-card__share-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92s2.92-1.31 2.92-2.92-1.31-2.92-2.92-2.92z"/></svg>
            Share
          </button>
        </div>
      </li>

      <li class="fft-quote-card">
        <div class="fft-quote-card__body">
          <div class="fft-quote-card__mark" aria-hidden="true">&ldquo;</div>
          <p class="fft-quote-card__text">
            Give me liberty, or give me death!
          </p>
          <div class="fft-quote-card__attribution">
            <p class="fft-quote-card__author">Patrick Henry</p>
            <p class="fft-quote-card__source">
              Speech to the Second Virginia Convention, March 23, 1775
              <span class="fft-quote-card__source-note">Recorded by biographer William Wirt decades later; the standard historically attributed version.</span>
            </p>
          </div>
        </div>
        <div class="fft-quote-card__footer">
          <button class="fft-quote-card__share" data-fft-share="1" type="button">
            <svg class="fft-quote-card__share-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92s2.92-1.31 2.92-2.92-1.31-2.92-2.92-2.92z"/></svg>
            Share
          </button>
        </div>
      </li>

      <li class="fft-quote-card">
        <div class="fft-quote-card__body">
          <div class="fft-quote-card__mark" aria-hidden="true">&ldquo;</div>
          <p class="fft-quote-card__text">
            These are the times that try men&rsquo;s souls.
          </p>
          <div class="fft-quote-card__attribution">
            <p class="fft-quote-card__author">Thomas Paine</p>
            <p class="fft-quote-card__source">The American Crisis, December 1776</p>
          </div>
        </div>
        <div class="fft-quote-card__footer">
          <button class="fft-quote-card__share" data-fft-share="2" type="button">
            <svg class="fft-quote-card__share-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92s2.92-1.31 2.92-2.92-1.31-2.92-2.92-2.92z"/></svg>
            Share
          </button>
        </div>
      </li>

    </ul>

    <div class="fft-quote-section__footer">
      <p class="fft-quote-section__footer-text">Primary source research &mdash; verified and cited</p>
      <a
        href="{{ section.settings.founders_words_url | default: '/pages/founders-words' }}"
        class="fft-quote-section__more-link"
      >
        More verified quotes from the founders &rarr;
      </a>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Founders Quote Cards",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Words That Built a Nation"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Section subtext",
      "default": "Direct quotes from the founders, verified against primary sources. Share the ones that still cut through."
    },
    {
      "type": "url",
      "id": "founders_words_url",
      "label": "\"More quotes\" page URL",
      "info": "Link to your Founders' Words page. Defaults to /pages/founders-words."
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Founders Quote Cards"
    }
  ]
}
{% endschema %}
